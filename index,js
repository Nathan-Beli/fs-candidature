<!DOCTYPE html>
<html>
<body>
    <h1>Portail Candidatures</h1>
    
    <% if (user) { %>
        <p>Connecté en tant que: <%= user.username %></p>
        
        <% if (user.id === "1016479613297369139") { %>
            <div id="admin-panel">
                <input type="text" id="app-name" placeholder="Nom de la candidature">
                <button onclick="generateLink()">Générer lien</button>
            </div>
        <% } %>

        <div id="app-list">
            <!-- Liste des candidatures stockées en DB -->
        </div>
    <% } else { %>
        <a href="/login">Connexion avec Discord</a>
    <% } %>

    <script>
        function generateLink() {
            // Logique pour générer un slug unique et l'envoyer au serveur
            const name = document.getElementById('app-name').value;
            fetch('/api/create', { method: 'POST', body: JSON.stringify({ name }) })
            .then(res => alert("Lien créé !"));
        }
    </script>
</body>
</html>
