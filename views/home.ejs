<%- include('partials/header', { pageTitle: 'Accueil' }) %>

<div class="container-narrow">
  <div class="hero">
    <img src="/img/logo.png" alt="<%= brand %>" />
    <div class="tag">Federal Studio</div>
    <h1>Portail de candidatures</h1>
    <p>Connecte-toi avec ton compte Discord pour accéder aux candidatures du serveur et postuler en quelques clics.</p>
    <% if (strategyReady) { %>
      <a href="/login" class="btn btn-discord">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="#fff"><path d="M20.3 4.4A19.8 19.8 0 0 0 15.4 3l-.2.5c1.6.4 2.9 1 4.2 1.9-2.3-1.2-4.8-1.7-7.4-1.7s-5.1.5-7.4 1.7c1.2-.8 2.6-1.5 4.2-1.9L8.6 3a19.8 19.8 0 0 0-5 1.4C1.2 8 .5 11.6.8 15.1a20 20 0 0 0 6 3l.8-1.3c-.7-.2-1.3-.5-1.9-.9l.5-.3c3.6 1.7 7.5 1.7 11.1 0l.5.3c-.6.4-1.2.7-1.9.9l.8 1.3a20 20 0 0 0 6-3c.4-4.1-.6-7.7-3.4-10.7ZM8.9 13.2c-1 0-1.7-.9-1.7-2s.8-2 1.7-2c1 0 1.7.9 1.7 2s-.8 2-1.7 2Zm6.2 0c-1 0-1.7-.9-1.7-2s.8-2 1.7-2c1 0 1.7.9 1.7 2s-.7 2-1.7 2Z"/></svg>
        Se connecter avec Discord
      </a>
    <% } else { %>
      <div class="alert alert-info">La connexion Discord n'est pas encore configurée. Voir le fichier <code>README.md</code>.</div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
